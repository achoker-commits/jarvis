# ============================================================
# JARVIS — Configuration (.env)
# Copiez ce fichier en .env et renseignez vos clés
# ============================================================


# ────────────────────────────────────────────────────────────
# REQUIS — Sans cette clé, JARVIS ne démarre pas
# ────────────────────────────────────────────────────────────

# Clé API Groq (LLM gratuit — llama-3.3-70b-versatile)
# Créez un compte GRATUIT sur : https://console.groq.com/
# Cliquez "API Keys" → "Create API Key"
# Format : gsk_...
GROQ_API_KEY=


# ────────────────────────────────────────────────────────────
# LLM — Fallback offline via Ollama (optionnel)
# Si absent : JARVIS utilise Groq cloud
# ────────────────────────────────────────────────────────────

# URL du serveur Ollama local
OLLAMA_HOST=http://localhost:11434

# Modèle Ollama à utiliser
OLLAMA_MODEL=mistral


# ────────────────────────────────────────────────────────────
# TTS — Synthèse vocale
# Chaîne de priorité : ElevenLabs → Edge TTS (Rémy) → pyttsx3
# Edge TTS est GRATUIT et utilisé par défaut — aucune clé requise
# ────────────────────────────────────────────────────────────

# Voix Edge TTS (gratuit, aucune clé requise)
# Options FR : fr-FR-RemyMultilingualNeural (voix Rémy, recommandée)
#              fr-FR-DeniseNeural (voix féminine)
#              fr-BE-GerardNeural (accent belge)
EDGE_VOICE=fr-FR-RemyMultilingualNeural

# ElevenLabs (qualité supérieure, payant après quota gratuit)
# Compte gratuit : https://elevenlabs.io/ (10 000 chars/mois)
# Clé sur : https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ID de la voix ElevenLabs (optionnel)
# Défaut : Rachel (21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI TTS (payant — alternative optionnelle)
OPENAI_API_KEY=


# ────────────────────────────────────────────────────────────
# WAKE WORD — Détection du mot de réveil (optionnel)
# Si absent : appuyez sur ENTRÉE pour parler (mode clavier)
# ────────────────────────────────────────────────────────────

# Picovoice Porcupine — wake word "jarvis" intégré
# Compte gratuit : https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=

# Vosk — modèle de reconnaissance offline (~50MB)
# Téléchargez sur : https://alphacephei.com/vosk/models
# Recommandé : vosk-model-small-fr-0.22
VOSK_MODEL_PATH=


# ────────────────────────────────────────────────────────────
# MÉMOIRE — Intégration Obsidian (optionnel)
# ────────────────────────────────────────────────────────────

# Chemin vers votre vault Obsidian
# macOS exemple : /Users/votre-nom/Documents/Mon Vault
OBSIDIAN_VAULT_PATH=


# ────────────────────────────────────────────────────────────
# WHISPER — Modèle de transcription
# ────────────────────────────────────────────────────────────

# Taille du modèle Whisper (faster-whisper en priorité)
# Options : tiny (~75MB) | base (~150MB) | small (~500MB) | medium (~1.5GB) | large (~3GB)
# Recommandé : small (rapide + précis en français belge)
WHISPER_MODEL=small


# ────────────────────────────────────────────────────────────
# PERSONNALITÉ JARVIS
# ────────────────────────────────────────────────────────────

# Nom de JARVIS (utilisé pour le wake word)
JARVIS_NAME=Jarvis

# Comment JARVIS vous appelle (patron, monsieur, Ali, ...)
USER_NAME=patron

# Langue principale
LANGUAGE=fr


# ────────────────────────────────────────────────────────────
# AUDIO — Paramètres avancés
# ────────────────────────────────────────────────────────────

# Durée de silence (en secondes) avant d'arrêter l'enregistrement
# 0.8 = réactif | 1.5 = plus patient si vous faites des pauses
SILENCE_THRESHOLD=0.8

# Durée maximale d'enregistrement par phrase (secondes)
MAX_RECORDING_SECONDS=30


# ────────────────────────────────────────────────────────────
# MÉMOIRE — Historique de conversation
# ────────────────────────────────────────────────────────────

# Nombre d'échanges conservés en mémoire de travail (RAM)
MAX_HISTORY=10


# ────────────────────────────────────────────────────────────
# DEBUG
# ────────────────────────────────────────────────────────────

# Activer les logs détaillés (true/false)
DEBUG=false
